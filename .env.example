# === API Keys ===
OPENAI_API_KEY=your-openai-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# === Pipeline Config ===
# Which image generator to use: "dalle" or "gemini"
IMAGE_GENERATOR=dalle

# ChatGPT model for structured prompt extraction
CHAT_MODEL=gpt-4o-mini

# DALL-E model version
DALLE_MODEL=dall-e-3

# Image size for DALL-E: "1024x1024", "1792x1024", or "1024x1792"
DALLE_IMAGE_SIZE=1024x1024

# Image quality for DALL-E: "standard" or "hd"
DALLE_IMAGE_QUALITY=standard
